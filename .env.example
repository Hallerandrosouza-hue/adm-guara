# ============================================
# Guará Manager - Environment Variables
# Copy this file to .env and fill in the values
# ============================================

# ---- Application ----
APP_NAME=Guará Manager
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ---- Database (PostgreSQL) ----
POSTGRES_USER=guara
POSTGRES_PASSWORD=guara_secret_2024
POSTGRES_DB=guara_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ---- JWT Authentication ----
JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-64-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- S3 / MinIO Storage ----
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=guara_minio
S3_SECRET_KEY=guara_minio_secret
S3_BUCKET_NAME=guara-uploads
S3_REGION=us-east-1

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- Rate Limiting ----
RATE_LIMIT_PER_MINUTE=100

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Guará Manager
